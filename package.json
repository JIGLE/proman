{
  "name": "proman",
  "version": "1.12.1",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "prestart": "node scripts/prestart.js",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "type-check": "tsc --noEmit",
    "verify": "npm run type-check && npm test",
    "verify:ci": "npm run type-check && npm run lint && npm test",
    "verify:no-native": "node scripts/verify-no-native.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:setup": "prisma db push && prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "security:scan": "node scripts/security-scan.js",
    "validate-env": "node scripts/validate-env.js",
    "security:audit": "npm audit --audit-level=moderate",
    "security:audit:fix": "npm audit fix",
    "security:zap": "node scripts/zap-scan.js",
    "security:all": "npm run security:scan && npm run security:audit",
    "load:smoke": "node scripts/load-test.js smoke",
    "load:test": "node scripts/load-test.js full",
    "load:stress": "node scripts/stress-test.js",
    "user:delete": "node scripts/delete-user.js",
    "package:helm:verify": "bash scripts/package-helm-and-verify.sh release-charts-temp $(node -e 'console.log(require(\"./package.json\").version)')",
    "db:check": "node scripts/check-db.js",
    "i18n:check": "node scripts/check-translations.js",
    "i18n:check:strict": "node scripts/check-translations.js --strict",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sendgrid/mail": "^8.1.6",
    "@types/leaflet": "^1.9.21",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.38.0",
    "isomorphic-dompurify": "^2.36.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.576.0",
    "next": "^16.2.4",
    "next-auth": "^4.24.14",
    "next-intl": "^4.11.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hot-toast": "^2.6.0",
    "react-leaflet": "^5.0.0",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.1"
  },
  "optionalDependencies": {
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/deep-eql": "^4.0.2",
    "@types/estree": "^1.0.8",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25",
    "@types/pako": "^2.0.4",
    "@types/raf": "^3.4.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "@vitest/coverage-v8": "^4.1.5",
    "artillery": "^2.0.31",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.0",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^7.1.12",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@opentelemetry/api": "1.4.1",
    "@hono/node-server": ">=1.19.13",
    "hono": ">=4.12.14",
    "protobufjs": ">=7.5.5"
  }
}
