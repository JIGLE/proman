{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(CLAUDE_CODE_REMOTE=true ./.claude/hooks/session-start.sh)",
      "Bash(npx eslint *)",
      "Bash(npx vitest *)",
      "Bash(npm run type-check)",
      "Bash(npm run lint)",
      "Bash(npm run verify:ci)",
      "Bash(npm test)",
      "Bash(npm audit *)",
      "Bash(npx prisma generate)",
      "Bash(npx tsc --noEmit)",
      "mcp__github__pull_request_read",
      "mcp__github__get_job_logs"
    ]
  }
}
