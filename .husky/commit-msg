#!/usr/bin/env sh
# Conventional Commits enforcement
# Pattern: <type>[optional scope][optional !]: <description>
# See: https://www.conventionalcommits.org/

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Skip merge commits
if echo "$COMMIT_MSG" | grep -qE "^Merge "; then
  exit 0
fi

# Skip revert commits generated by git
if echo "$COMMIT_MSG" | grep -qE "^Revert "; then
  exit 0
fi

# Skip Dependabot commits (already follow a consistent format)
if echo "$COMMIT_MSG" | grep -qE "^(deps|ci|docker)\(dependabot"; then
  exit 0
fi

PATTERN="^(feat|fix|chore|docs|style|refactor|test|ci|perf|build|deps|revert)(\(.+\))?(!)?: .{1,}"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo ""
  echo "  Commit message does not follow Conventional Commits format."
  echo ""
  echo "  Expected:  <type>[scope][!]: <description>"
  echo "  Examples:"
  echo "    feat(auth): add OAuth2 Google login"
  echo "    fix(property): prevent crash when building ID is null"
  echo "    chore(release): bump version to 1.14.0"
  echo "    docs: update README with deployment instructions"
  echo ""
  echo "  Valid types: feat fix chore docs style refactor test ci perf build deps revert"
  echo ""
  echo "  Your message: $COMMIT_MSG"
  echo ""
  exit 1
fi
